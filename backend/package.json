{
  "name": "stellarguard-backend",
  "version": "1.0.0",
  "description": "StellarGuard backend API — decentralized multi-sig treasury & payroll on Stellar",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "migrate": "node-pg-migrate up -m ../database/migrations --database-url-var DATABASE_URL",
    "migrate:rollback": "node-pg-migrate down -m ../database/migrations --database-url-var DATABASE_URL",
    "lint": "eslint src/",
    "test": "jest --forceExit --detectOpenHandles"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^12.1.0",
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "node-pg-migrate": "^7.5.2",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "eslint": "^9.5.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "engines": { "node": ">=18.0.0" }
}
